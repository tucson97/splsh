{% comment %}
  Sección: Personalizador Cultr
  Agregala a la plantilla del producto "Custom Case" (y opcionalmente a los
  productos de diseño para el selector de modelo con stock real).
  Configurá la URL del backend en los settings de la sección.
{% endcomment %}

<div
  id="cultr-customizer"
  data-app-url="{{ section.settings.app_url }}"
  data-product-id="{{ product.id }}"
  data-price="{{ product.price | money }}"
>
  <div class="cultr-c__stage">
    <canvas id="cultr-canvas" width="260" height="520"></canvas>
    <div class="cultr-c__hint" id="cultr-hint">Subí una foto y arrastrala para acomodarla</div>
  </div>

  <div class="cultr-c__controls">
    <div class="cultr-c__step">
      <span class="cultr-c__label">1 · Tu modelo</span>
      <div class="cultr-c__models" id="cultr-models">
        {% for variant in product.variants %}
          <button
            type="button"
            class="cultr-c__model"
            data-variant-id="{{ variant.id }}"
            data-sku="{{ variant.sku }}"
          >
            {{ variant.title }}
          </button>
        {% endfor %}
      </div>
    </div>

    <div class="cultr-c__step">
      <span class="cultr-c__label">2 · Tu foto</span>
      <label class="cultr-c__upload">
        <input type="file" id="cultr-file" accept="image/*" hidden>
        <span id="cultr-upload-text">Subir foto</span>
      </label>
      <div class="cultr-c__zoom" id="cultr-zoom-wrap" hidden>
        <span>Zoom</span>
        <input type="range" id="cultr-zoom" min="1" max="3" step="0.01" value="1">
      </div>
    </div>

    <button type="button" class="cultr-c__add" id="cultr-add" disabled>
      Agregar al carrito — {{ product.price | money }}
    </button>
    <div class="cultr-c__status" id="cultr-status"></div>
  </div>
</div>

<script src="{{ 'cultr-customizer.js' | asset_url }}" defer></script>
<link rel="stylesheet" href="{{ 'cultr-customizer.css' | asset_url }}">

{% schema %}
{
  "name": "Personalizador Cultr",
  "settings": [
    {
      "type": "url",
      "id": "app_url",
      "label": "URL del backend de la app (ej: https://cultr-app.up.railway.app)"
    }
  ],
  "presets": [{ "name": "Personalizador Cultr" }]
}
{% endschema %}
